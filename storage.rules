rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Logo do mercado: qualquer um pode visualizar (aparece no topo do
    // app e não é informação sensível), mas só o próprio mercado pode
    // enviar/trocar o arquivo do seu logo.
    match /logos/{adminUid} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == adminUid;
    }
  }
}
